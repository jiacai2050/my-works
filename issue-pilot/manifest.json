{
  "manifest_version": 3,
  "name": "IssuePilot",
  "version": "0.1.0",
  "description": "Help Chinese developers write professional GitHub issue comments in English.",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content/github.js", "content/ui.js", "content/content.js"],
      "css": ["styles/content.css"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png"
  },
  "commands": {
    "open-draft": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open IssuePilot draft panel"
    }
  }
}
